# ============================================
#  BZR HOMES — BACKEND ENVIRONMENT VARIABLES
#  Copy this file to .env and fill in your values
#  NEVER commit .env to git
# ============================================

# Server
PORT=3000
NODE_ENV=development

# Your deployed frontend URL (for CORS in production)
# Example: https://bzrhomes.in
FRONTEND_URL=http://localhost:3000

# Email Configuration (Gmail)
# 1. Use your Gmail address
# 2. Enable 2FA on Gmail
# 3. Go to Google Account > Security > App Passwords
# 4. Create an App Password and paste it here
EMAIL_FROM=your_gmail@gmail.com
EMAIL_PASSWORD=your_gmail_app_password_here

# Where to send enquiry notifications (owner's email)
EMAIL_TO=yogesh@bzrhomes.com
